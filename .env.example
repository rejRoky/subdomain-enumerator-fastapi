# Copy to .env and fill in values

# Optional VirusTotal free API key
VT_API_KEY=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Max in-memory jobs before oldest is evicted
MAX_JOBS=100

# Seconds before completed/failed jobs are auto-purged
JOB_TTL_SECONDS=3600

# Allowed CORS origins (JSON array)
CORS_ORIGINS=["*"]

# Set to true only in local dev
DEBUG=false
