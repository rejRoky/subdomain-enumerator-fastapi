# Copy to .env and fill in values

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
CORS_ORIGINS=["*"]

# ── Optional API keys ─────────────────────────────────────────────────────────
VT_API_KEY=

# ── Job settings ──────────────────────────────────────────────────────────────
# Seconds before completed/failed jobs are purged (default 24 h)
JOB_TTL_SECONDS=86400

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=subdomain_enumerator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/subdomain_enumerator

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ports (host-side overrides) ───────────────────────────────────────────────
PORT=8000
FRONTEND_PORT=8501
FLOWER_PORT=5555
POSTGRES_PORT=5432
REDIS_PORT=6379
